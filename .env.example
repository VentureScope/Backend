# VentureScope Backend Environment Configuration
# Copy this file to .env and customize values for your environment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
PROJECT_NAME=VentureScope
DEBUG=false
# development, staging, production
ENVIRONMENT=development

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Local development (direct connection to host PostgreSQL)
DATABASE_URL=postgresql+asyncpg://venturescope:venturescope@localhost:5432/venturescope

# Docker development (automatically used when running in docker-compose)
# Note: docker-compose.yml overrides DATABASE_URL for container networking
DOCKER_DATABASE_URL=postgresql+asyncpg://venturescope:venturescope@postgres:5432/venturescope

# Testing databases
TEST_DOCKER_DATABASE_URL=postgresql+asyncpg://venturescope:venturescope@postgres:5432/venturescope_test
TEST_DATABASE_URL=postgresql+asyncpg://venturescope:venturescope@localhost:5432/venturescope_test

# Production example (replace with your actual database URL)
# DATABASE_URL=postgresql+asyncpg://username:password@your-db-host:5432/venturescope

# =============================================================================
# JWT TOKEN CONFIGURATION
# =============================================================================
# IMPORTANT: Change this in production! Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
# 24 hours
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Token cleanup settings
# 1 hour
TOKEN_CLEANUP_INTERVAL_SECONDS=3600

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# DEVELOPMENT SETUP (Recommended)
# Allow all origins - easiest for development
CORS_ORIGINS=*

# ALTERNATIVE DEVELOPMENT SETUP
# Specify exact origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ALTERNATIVE DEVELOPMENT SETUP  
# Specify origins as JSON array
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# PRODUCTION SETUP
# CORS_ORIGINS=["https://yourapp.com","https://www.yourapp.com"]
# FRONTEND_URL=https://yourapp.com

# Primary frontend URL (fallback if CORS_ORIGINS not set in production)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# CORS BEHAVIOR BY ENVIRONMENT
# =============================================================================
# 
# DEVELOPMENT (ENVIRONMENT=development):
#   - CORS_ORIGINS=* : Allows ALL origins (recommended for dev)
#   - CORS_ORIGINS=specific : Uses only those specific origins
#   - No restrictions on localhost/dev origins
#
# PRODUCTION (ENVIRONMENT=production):
#   - CORS_ORIGINS=* : Automatically falls back to FRONTEND_URL (secure)
#   - CORS_ORIGINS=specific : Uses only those origins
#   - Automatically filters out localhost origins for security
#

# =============================================================================
# OAUTH CONFIGURATION
# =============================================================================

# Google OAuth 2.0
# 1. Go to Google Cloud Console: https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable Google+ API and OAuth consent screen
# 4. Create OAuth 2.0 credentials (Web application)
# 5. Add authorized redirect URIs: http://localhost:8000/api/auth/oauth/google/callback
# 6. Copy Client ID and Client Secret here
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# GitHub OAuth App
# 1. Go to GitHub Developer Settings: https://github.com/settings/developers
# 2. Create a new OAuth App
# 3. Set Authorization callback URL: http://localhost:8000/api/auth/oauth/github/callback
# 4. Copy Client ID and Client Secret here
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/oauth/github/callback

# OAuth state secret for CSRF protection
# Generate with: openssl rand -hex 32
# IMPORTANT: This should be different from your JWT SECRET_KEY
OAUTH_STATE_SECRET=your-oauth-state-secret-here

# OAuth state expiration in minutes (default: 10 minutes for security)
OAUTH_STATE_EXPIRE_MINUTES=10

# =============================================================================
# AI EMBEDDINGS CONFIGURATION
# =============================================================================
# Configuration for user profile embeddings via Hosted LLM (OpenAI-compatible wrapper)
END_POINT=https://api.openai.com/v1
HOSTED_LLM_TOKEN=your-hosted-llm-token-here

# The exact model name to use when requesting the embedding
EMBEDDING_MODEL_NAME=text-embedding-3-small

# Note: If your LLM provider returns a different dimension (e.g., 1536),
# you must either append dimensions=384 to the API call or change the
# Vector(384) schema inside the database to match!
EMBEDDING_DIMENSIONS=384

# =============================================================================
# CHAT / LLM COMPLETIONS CONFIGURATION
# =============================================================================
# Model used for the personalized chatbot (must be supported by your hosted endpoint)
CHAT_MODEL_NAME=gpt-4o-mini

# Maximum tokens the model can generate per reply
CHAT_MAX_TOKENS=800

# Sampling temperature: 0.0 = deterministic, 1.0 = very creative
CHAT_TEMPERATURE=0.7

# =============================================================================
# S3  STORAGE CONFIGURATION (for CV storage)
# =============================================================================

AWS_ACCESS_KEY_ID=your-storage-access-key
AWS_SECRET_ACCESS_KEY=your-storage-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=cvs  


S3_ENDPOINT_URL=your-s3-endpoint-url 